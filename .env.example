# Copy this file to .env and fill in your values.
# Add the same variables in Netlify → Site Settings → Environment Variables.
# NEVER commit .env to git.

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: gemini | anthropic | openai | groq
# Default is gemini (free tier available, Pro subscription gives $10/mo credit)
AI_PROVIDER=gemini

# Optional: override the default model for the chosen provider
# gemini    → gemini-2.0-flash (default) | gemini-2.5-flash | gemini-2.0-flash-lite
# anthropic → claude-sonnet-4-20250514 (default) | claude-haiku-4-5-20251001
# openai    → gpt-4o-mini (default) | gpt-4o
# groq      → llama-3.3-70b-versatile (default) | llama-3.1-8b-instant
# AI_MODEL=gemini-2.0-flash

# ── API Keys (only the one matching AI_PROVIDER is required) ──────────────────
# All keys support comma-separated values for automatic rotation on rate limits.
# Example: GEMINI_KEY=AIza...key1,AIza...key2,AIza...key3
#
# Gemini — free tier at aistudio.google.com, $10/mo credit with Google Pro
GEMINI_KEY=AIza...

# Anthropic — console.anthropic.com (pay-per-use, no free tier)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — platform.openai.com (pay-per-use, no free tier)
# OPENAI_API_KEY=sk-...

# Groq — console.groq.com (free tier with rate limits, no web search)
# GROQ_API_KEY=gsk_...

# ── Supabase — https://supabase.com/dashboard/project/_/settings/api ─────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# ── SerpApi (Google Jobs) — https://serpapi.com ─────────────────────────────────
# Free tier: 100 requests/month. Used for real live job listings.
# Supports comma-separated keys for rotation: SERPAPI_KEY=key1,key2
SERPAPI_KEY=your_serpapi_key

# ── Logging & Diagnostics ────────────────────────────────────────────────────
# Set DEBUG=true to enable structured JSON logging in Netlify function logs
DEBUG=false
# Set VITE_DEBUG=true to enable structured JSON logging in the browser console
# (can also be toggled per-session in Settings → Developer tools)
VITE_DEBUG=false
